{
  "expo": {
    "name": "KKorea Hangul",
    "slug": "kkorea-hangul",
    "scheme": "kkorea-hangul",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-full.png",
      "resizeMode": "cover",
      "backgroundColor": "#E7DFF6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kataro92.kkorea-hangul"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EEF2FF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.kataro92.kkoreahangul"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing"
    ]
  }
}
